# ---------------------------------------------------------------------------
# Client-safe values (VITE_* are baked into the frontend build at build time).
# These are NOT secrets — they're protected by Postgres RLS, not by secrecy.
# In this project they live in the COMMITTED apps/web/.env.production file.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGc...

# ---------------------------------------------------------------------------
# Server-only secrets. NEVER commit these. Set them in the Vercel dashboard
# (Project Settings -> Environment Variables). No MCP tool in this session
# can set them for you — this is a manual step.
# ---------------------------------------------------------------------------

# Service-role key: bypasses RLS. Used by api/crawl.ts (writing
# properties/enrichments as a system job, no end-user JWT context there) and
# by every /api/admin/* route (role changes, invitations, advisor
# connections) — required for the admin dashboard to work at all.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret checked by api/crawl.ts against the Authorization header,
# so only the GitHub Actions cron job (or you, manually) can trigger a crawl.
CRON_SECRET=

# When "false", server/lib/crawl/*.ts call the real Boliga/Boligsiden JSON
# APIs instead of reading from local fixtures. Note that enrichment
# (server/lib/crawl/enrich.ts) is still mock-only either way — real BBR/OIS
# clients await Datafordeler credentials.
CRAWL_MOCK_MODE=true

# BBR enrichment (server/lib/enrichment-sources/bbr.ts) via Datafordeler's
# entity-based GraphQL service. DATAFORDELER_API_KEY is the API key issued
# through Datafordeler's self-service portal for the BBR GraphQL service —
# this is NOT the older REST "tjenestebruger" username/password, which only
# works for fetching the GraphQL schema, not for querying entity data.
# BBR_MOCK_MODE stays "true" (mock heating-installation data) until a key
# exists; see README "Data ingest status".
BBR_MOCK_MODE=true
DATAFORDELER_API_KEY=
# Overrides the per-register version segment in the endpoint URL
# (https://graphql.datafordeler.dk/BBR/<version>) if BBR's GraphQL schema
# gets bumped past v1.
# DATAFORDELER_BBR_VERSION=v1

# Address/cadastral enrichment (server/lib/enrichment-sources/address-lookup.ts).
# DAWA (dawa.aws.dk) is being retired ~2026-08-17; this now calls DAR
# (Danmarks Adresseregister) for id_lokalid/matrikelnr/ejerlav and a separate
# zone-status endpoint for byzone/landzone/sommerhusomraade, fetched
# independently so one failing doesn't blank the other. No auth required for
# either. ADDRESS_LOOKUP_MOCK_MODE stays "true" until both live response
# shapes are confirmed; see README "Data ingest status".
ADDRESS_LOOKUP_MOCK_MODE=true
# ADDRESS_LOOKUP_DAR_API_BASE=
# ADDRESS_LOOKUP_ZONE_API_BASE=

# Matriklen (cadastral parcel) enrichment
# (server/lib/enrichment-sources/matrikel.ts): same Datafordeler GraphQL
# pattern and DATAFORDELER_API_KEY as BBR above, just a different register —
# no separate credential needed. MATRIKEL_MOCK_MODE stays "true" (mock
# registered-area value) until the live Jordstykke schema is confirmed; see
# README "Data ingest status".
MATRIKEL_MOCK_MODE=true
# Overrides the per-register version segment in the endpoint URL
# (https://graphql.datafordeler.dk/Matrikel/<version>).
# DATAFORDELER_MATRIKEL_VERSION=v2
# DATAFORDELER_MATRIKEL_API_BASE=

# Ejendomsvurdering (official public property valuation) enrichment
# (server/lib/enrichment-sources/ejendomsvurdering.ts): Datafordeler's VUR
# GraphQL service, same DATAFORDELER_API_KEY as BBR/Matriklen above, keyed
# by the matrikelnr/ejerlav pair address-lookup.ts already resolves.
# EJENDOMSVURDERING_MOCK_MODE stays "true" (mock valuation) until the live
# schema and the matrikelnr/ejerlav lookup-key assumption are confirmed; see
# README "Data ingest status".
EJENDOMSVURDERING_MOCK_MODE=true
# Overrides the per-register version segment in the endpoint URL
# (https://graphql.datafordeler.dk/VUR/<version>).
# DATAFORDELER_VUR_VERSION=v2
# DATAFORDELER_VUR_API_BASE=

# Noise enrichment (server/lib/enrichment-sources/stoejkort.ts): Miljøstyrelsens
# støjkort (road/rail traffic noise, Lden) via a WFS on geoserver.plandata.dk.
# The "Noise Map" theme group requires contacting Miljøstyrelsen for access —
# not a fully open self-serve endpoint. STOEJKORT_MOCK_MODE stays "true"
# (deterministic mock Lden value) until access is confirmed; see README
# "Data ingest status".
STOEJKORT_MOCK_MODE=true
# STOEJKORT_API_BASE=

# ---------------------------------------------------------------------------
# Crawl tuning (all optional; defaults live in server/lib/crawl/). The crawl
# clients hit Boliga's and Boligsiden's UNOFFICIAL frontend JSON APIs:
# unauthenticated, undocumented, and liable to change shape without notice.
# Malformed records are skipped and counted; a failed source is reported in
# the /api/crawl response (HTTP 502) without aborting the other source.
# ---------------------------------------------------------------------------
CRAWL_MAX_PAGES=10          # pages per source, per run
CRAWL_PAGE_SIZE=100         # listings requested per page
CRAWL_MAX_LISTINGS=1000     # hard cap per source, per run
CRAWL_DELAY_MS=250          # polite delay between page requests
CRAWL_TIMEOUT_MS=10000      # per-request timeout
# CRAWL_MUNICIPALITY_CODES=851,751   # optional Boliga municipality filter
# BOLIGA_API_BASE=            # override if the unofficial endpoint moves
# BOLIGSIDEN_API_BASE=

# Postal code (postnummer) ranges to scrape, as comma-separated "min-max"
# intervals — e.g. "9000-9900,6000-6600" to crawl both North Jutland and
# Aarhus. Listings outside every configured interval are fetched-then-
# discarded (client-side filter, so it's correct even if the upstream API
# ignores the range). Widen/change later just by editing this.
CRAWL_ZIP_RANGES=9000-9900

# Legacy single-range fallback, only used when CRAWL_ZIP_RANGES is unset.
# CRAWL_ZIP_MIN=9000
# CRAWL_ZIP_MAX=9900

# ---------------------------------------------------------------------------
# Search API tuning.
# ---------------------------------------------------------------------------
# Hard ceiling on `limit` for GET /api/properties, regardless of what the
# caller requests. Raise/lower later without a code change.
SEARCH_MAX_PAGE_SIZE=100

# CORS: the frontend origin allowed to call /api/*. Defaults to "*" when
# unset — set it to the deployed frontend URL in production. Also used to
# build links in invitation and notification emails (e.g. FRONTEND_URL/property/:id).
FRONTEND_URL=

# ---------------------------------------------------------------------------
# Notification email (api/notify.ts, server/lib/notify/*). Sends an email via
# Resend (https://resend.com) when a saved search's alert cadence is due and
# new listings match its filters.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
# Must be a verified sender/domain in the Resend dashboard.
NOTIFY_FROM_EMAIL=alerts@yourdomain.dk

# ---------------------------------------------------------------------------
# GitHub Actions secrets (set in repo Settings -> Secrets and variables ->
# Actions). Needed by .github/workflows/crawl.yml and deploy.yml.
# ---------------------------------------------------------------------------
VERCEL_URL=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
