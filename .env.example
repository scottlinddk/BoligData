# ---------------------------------------------------------------------------
# Client-safe values (VITE_* are baked into the frontend build at build time).
# These are NOT secrets — they're protected by Postgres RLS, not by secrecy.
# In this project they live in the COMMITTED apps/web/.env.production file.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGc...

# ---------------------------------------------------------------------------
# Server-only secrets. NEVER commit these. Set them in the Vercel dashboard
# (Project Settings -> Environment Variables). No MCP tool in this session
# can set them for you — this is a manual step.
# ---------------------------------------------------------------------------

# Service-role key: bypasses RLS. Used by api/crawl.ts (writing
# properties/enrichments as a system job, no end-user JWT context there) and
# by every /api/admin/* route (role changes, invitations, advisor
# connections) — required for the admin dashboard to work at all.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret checked by api/crawl.ts against the Authorization header,
# so only the GitHub Actions cron job (or you, manually) can trigger a crawl.
CRON_SECRET=

# When "false", server/lib/crawl/*.ts call the real Boliga/Boligsiden JSON
# APIs instead of reading from local fixtures. Note that enrichment
# (server/lib/crawl/enrich.ts) is still mock-only either way — real BBR/OIS
# clients await Datafordeler credentials.
CRAWL_MOCK_MODE=true

# ---------------------------------------------------------------------------
# Crawl tuning (all optional; defaults live in server/lib/crawl/). The crawl
# clients hit Boliga's and Boligsiden's UNOFFICIAL frontend JSON APIs:
# unauthenticated, undocumented, and liable to change shape without notice.
# Malformed records are skipped and counted; a failed source is reported in
# the /api/crawl response (HTTP 502) without aborting the other source.
# ---------------------------------------------------------------------------
CRAWL_MAX_PAGES=10          # pages per source, per run
CRAWL_PAGE_SIZE=100         # listings requested per page
CRAWL_MAX_LISTINGS=1000     # hard cap per source, per run
CRAWL_DELAY_MS=250          # polite delay between page requests
CRAWL_TIMEOUT_MS=10000      # per-request timeout
# CRAWL_MUNICIPALITY_CODES=851,751   # optional Boliga municipality filter
# BOLIGA_API_BASE=            # override if the unofficial endpoint moves
# BOLIGSIDEN_API_BASE=

# Postal code (postnummer) range to scrape. Listings outside this range are
# fetched-then-discarded (client-side filter, so it's correct even if the
# upstream API ignores the range). Widen/change later just by editing these.
CRAWL_ZIP_MIN=9000
CRAWL_ZIP_MAX=9900

# ---------------------------------------------------------------------------
# Search API tuning.
# ---------------------------------------------------------------------------
# Hard ceiling on `limit` for GET /api/properties, regardless of what the
# caller requests. Raise/lower later without a code change.
SEARCH_MAX_PAGE_SIZE=100

# CORS: the frontend origin allowed to call /api/*. Defaults to "*" when
# unset — set it to the deployed frontend URL in production. Also used to
# build links in invitation and notification emails (e.g. FRONTEND_URL/property/:id).
FRONTEND_URL=

# ---------------------------------------------------------------------------
# Notification email (api/notify.ts, server/lib/notify/*). Sends an email via
# Resend (https://resend.com) when a saved search's alert cadence is due and
# new listings match its filters.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
# Must be a verified sender/domain in the Resend dashboard.
NOTIFY_FROM_EMAIL=alerts@yourdomain.dk

# ---------------------------------------------------------------------------
# GitHub Actions secrets (set in repo Settings -> Secrets and variables ->
# Actions). Needed by .github/workflows/crawl.yml and deploy.yml.
# ---------------------------------------------------------------------------
VERCEL_URL=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
